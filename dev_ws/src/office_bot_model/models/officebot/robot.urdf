                    <p1>0.00873816137</p1>
                    <p2>0.0603649760</p2>
                    <k3>-54.7462075</k3>
                </distortion>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.007</stddev>
                </noise>
            </camera>
        </sensor>
    </gazebo>
