    <joint name="base_lidar" type="fixed">
        <origin xyz="1.561251128379126385e-17 -6.9388939039072283776e-18 0.64000000000000001332"
            rpy="3.141592653589793116 -0 0" />
        <parent link="base_footprint" />
        <child link="lidar_link" />
        <axis xyz="0 0 1" />
    </joint>


    <!-- Mecanum wheel friction properties -->
    <gazebo reference="wheel_fl">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>1.0</mu>
                        <mu2>0.012</mu2>
                        <fdir1>1 1 0</fdir1>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>
    <gazebo reference="wheel_fr">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>1.0</mu>
                        <mu2>0.012</mu2>
                        <fdir1>1 1 0</fdir1>
                    </ode>
                </friction>
            </surface>

        </collision>
    </gazebo>
    <gazebo reference="wheel_rl">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>1.0</mu>
                        <mu2>0.012</mu2>
                        <fdir1>1 1 0</fdir1>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>
    <gazebo reference="wheel_rr">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>1.0</mu>
                        <mu2>0.012</mu2>
                        <fdir1>1 -1 0</fdir1>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <gazebo reference="lidar_link">
        <sensor name='unitree_l2_lidar' type='gpu_lidar'>
            <pose relative_to='lidar_link'>0 0 0 0 0 0</pose>
            <topic>lidar</topic>
            <ignition_frame_id>lidar_link</ignition_frame_id>
            <update_rate>10</update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>2000</samples> <!-- 360° / 0.18° ≈ 2000 samples -->
                        <resolution>1</resolution>
                        <min_angle>-3.14159265359</min_angle>
                        <max_angle>3.14159265359</max_angle>
                    </horizontal>
                    <vertical>
                        <samples>32</samples>
                        <resolution>1</resolution>
                        <min_angle>-0.261799</min_angle> <!-- -15 degrees in radians -->
                        <max_angle>0.261799</max_angle>  <!-- +15 degrees in radians -->
                    </vertical>
                </scan>
                <range>
                    <min>0.1</min>
                    <max>40.0</max>
                    <resolution>0.01</resolution>
                </range>
            </ray>
            <always_on>1</always_on>
            <visualize>
                true</visualize>
        </sensor>

    </gazebo>

    <gazebo reference="base_footprint">
        <sensor name="imu_sensor" type="imu">
            <always_on>1</always_on>
            <update_rate>1</update_rate>
            <visualize>true</visualize>
            <topic>imu</topic>
        </sensor>
    </gazebo>

    <ros2_control name="IgnitionSystem" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>

        <joint name="base_drawer1">
            <command_interface name="position">
                <param name="min">0</param>
                <param name="max">1</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_value">0</param>
            </state_interface>
            <state_interface name="velocity" />

        </joint>
        <joint name="base_drawer2">
            <command_interface name="position">
                <param name="min">0</param>
                <param name="max">1</param>
            </command_interface>

            <state_interface name="position">
                <param name="initial_value">0</param>
            </state_interface>
            <state_interface name="velocity" />
        </joint>
        <joint name="base_drawer3">
            <command_interface name="position">
                <param name="min">0</param>
                <param name="max">1</param>
            </command_interface>

            <state_interface name="position">
                <param name="initial_value">0</param>
            </state_interface>
            <state_interface name="velocity" />
        </joint>
        <joint name="base_drawer4">
            <command_interface name="position">
                <param name="min">0</param>
                <param name="max">1</param>
            </command_interface>
            <state_interface
                name="position">
                <param name="initial_value">0</param>
            </state_interface>
            <state_interface
                name="velocity" />
        </joint>

        <joint name="base_wheel_fr">
            <command_interface name="velocity">
                <param name="min">-1</param>
                <param name="max">1</param>
            </command_interface>
            <state_interface name="velocity" />
            <state_interface name="position" />
        </joint>
        <joint name="base_wheel_rr">
            <command_interface name="velocity">
                <param name="min">-1</param>
                <param name="max">1</param>
            </command_interface>
            <state_interface name="velocity" />
            <state_interface name="position" />
        </joint>
        <joint name="base_wheel_fl">
            <command_interface name="velocity">
                <param name="min">-1</param>
                <param name="max">1</param>
            </command_interface>
            <state_interface name="velocity" />
            <state_interface name="position" />
        </joint>
        <joint name="base_wheel_rl">
            <command_interface name="velocity">
                <param name="min">-1</param>
                <param name="max">1</param>
            </command_interface>
            <state_interface name="velocity" />
            <state_interface name="position" />
        </joint>
    </ros2_control>

    <!-- Gazebo Plugins -->
    <gazebo>
        <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>
                /home/thedevmanek/office_bot/dev_ws/src/office_bot_model/controllers/officebotcontroller.yaml
            </parameters>
            <ros>
                <remapping>/mecanum_drive_controller/reference:=/cmd_vel</remapping>
                <remapping>/mecanum_drive_controller/odometry:=/odom</remapping>
                <remapping>/mecanum_drive_controller/tf_odometry:=/tf</remapping>
            </ros>
        </plugin>

        <plugin filename="ignition-gazebo-user-commands-system"
            name="ignition::gazebo::systems::UserCommands"></plugin>
        <plugin filename="ignition-gazebo-scene-broadcaster-system"
            name="ignition::gazebo::systems::SceneBroadcaster"></plugin>
        <plugin filename="libignition-gazebo-imu-system.so"
            name="ignition::gazebo::systems::Imu">
        </plugin>
        <plugin
            filename="libignition-gazebo-sensors-system.so"
            name="ignition::gazebo::systems::Sensors">
            <render_engine>ogre2</render_engine>
        </plugin>
    </gazebo>

</robot>