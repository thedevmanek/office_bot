<robot name="officebot">
    <link name="base_footprint">
        <!-- No inertial element here -->
    </link>

    <joint name="dummy_root" type="fixed">
        <parent link="base_footprint" />
        <child link="base" />
        <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>
    <link name="base">
        <visual>
            <origin xyz="0 0 0" rpy="0 -0 0" />
            <geometry>
                <mesh filename="file:///opt/officebot/models/officebot/base.stl" />
            </geometry>
            <material name="base_material">
                <color rgba="0.1 0.1 0.1 1.0" />
                <specular>0.9 0.9 0.9 0.6</specular>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 -0 0" />
            <geometry>
                <mesh filename="file:///opt/officebot/models/officebot/base.stl" />
            </geometry>
        </collision>
        <inertial>
            <origin xyz="-1.1402394615806152526e-05 0.0058167257603785474732 0.20057979617316373799"
                rpy="0 0 0" />
            <mass value="5" />
            <inertia ixx="0.0369" ixy="0.0"
                ixz="0.0" iyy="0.0317"
                iyz="0.0" izz="0.0177" />
        </inertial>
    </link>

    <link name="drawer1">
