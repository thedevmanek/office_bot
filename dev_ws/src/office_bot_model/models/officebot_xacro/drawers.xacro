<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="officebot_drawers">
    <xacro:macro name="officebot_drawer" params="link_name joint_name z_offset visual_x:=0.015004444442000011706">
        <link name="${link_name}">
            <visual>
                <origin xyz="${visual_x} 1.0500000000000000444 -0.20100000000000001199" rpy="1.570796326794896558 0 0" />
                <geometry>
                    <mesh filename="${mesh_uri_prefix}drawer.stl" />
                </geometry>
                <material name="drawer_material">
                    <color rgba="0.64705882352941179736 0.64705882352941179736 0.64705882352941179736 1.0" />
                </material>
            </visual>
            <collision>
                <origin xyz="${visual_x} 1.0500000000000000444 -0.20100000000000001199" rpy="1.570796326794896558 0 0" />
                <geometry>
                    <mesh filename="${mesh_uri_prefix}drawer.stl" />
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0.11500444463622183644 0.017863356300829913437 -0.20135771129566992776" rpy="0 0 0" />
                <mass value="1.3157567401165588539" />
                <inertia ixx="0.025117376745737180627" ixy="4.6518674608217020318e-12" ixz="-2.9189657039480768947e-11" iyy="0.033720984998443788438" iyz="-2.441660906402222698e-05" izz="0.011129479641923002015" />
            </inertial>
        </link>
        <joint name="${joint_name}" type="fixed">
            <origin xyz="0.11500980138576723244 -0.20500000000000001554 ${z_offset}" rpy="-1.570796326794896558 0 3.141592653589793116" />
            <parent link="base" />
            <child link="${link_name}" />
        </joint>
    </xacro:macro>

    <xacro:macro name="officebot_drawers" params="mesh_uri_prefix">
        <xacro:officebot_drawer link_name="drawer_1" joint_name="base_drawer1" z_offset="0.56999968326568606347" />
        <xacro:officebot_drawer link_name="drawer_2" joint_name="base_drawer2" z_offset="0.46999968326568986043" visual_x="0.015004444442000025584" />
        <xacro:officebot_drawer link_name="drawer_3" joint_name="base_drawer3" z_offset="0.36999968326568610788" />
        <xacro:officebot_drawer link_name="drawer_4" joint_name="base_drawer4" z_offset="0.26999968326568613008" />
    </xacro:macro>
</robot>
